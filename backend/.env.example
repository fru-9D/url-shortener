# Copy to .env and fill in values for local development

# Database
DATABASE_URL=postgresql+asyncpg://snip:snip_dev@localhost:5432/snip

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production
HMAC_KEY=change-me-in-production

# Environment: development | staging | production
ENVIRONMENT=development

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES
SES_FROM_EMAIL=noreply@snip.io

# KMS
KMS_KEY_ARN=

# Google Safe Browsing
GOOGLE_SAFE_BROWSING_API_KEY=

# Mixpanel
MIXPANEL_TOKEN=

# Cloudflare
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
SNIP_BASE_URL=https://snip.io

# SQS
SQS_CLICKS_URL=
SQS_MIXPANEL_URL=
SQS_MAIL_EVENTS_URL=

# App frontend base URL (used in transactional email links)
APP_BASE_URL=https://app.snip.io

# Sentry (optional)
SENTRY_DSN=
